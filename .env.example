# Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=monte-data

# LLM Provider (pick ONE)
# Option A: OpenRouter (recommended — one key for all models)
OPENROUTER_API_KEY=

# Option B: Groq (fast inference)
# GROQ_API_KEY=

# Global CLI note:
# The installed `monte` CLI can also store provider credentials in ~/.monte/config.json via:
#   monte config set-provider openrouter
#   monte config set-api-key <key>
# The API server still reads its credentials from environment variables like this file.

# Optional: override default models
# LLM_MODEL=openai/gpt-oss-20b              # Standard evaluation model
# LLM_REASONING_MODEL=openai/gpt-oss-120b   # Complex decision model
# SIMULATION_BATCH_SIZE=100                 # Clones assigned to each persisted simulation batch
# SIMULATION_DECISION_CONCURRENCY=10        # Max in-flight LLM decision requests per worker process
# SIMULATION_ACTIVE_FRONTIER=100            # Clones each worker batch keeps active in the frontier scheduler
# SIMULATION_CONCURRENCY=10                 # Legacy alias for SIMULATION_DECISION_CONCURRENCY
# SIMULATION_WORKER_CONCURRENCY=5           # BullMQ worker concurrency in development (production defaults to 20)
# SIMULATION_DECISION_BATCH_SIZE=20         # Clones to batch into one structured LLM fork evaluation
# SIMULATION_DECISION_BATCH_FLUSH_MS=40     # Reported decision flush window / compatibility knob
# LLM_RPM_LIMIT=                            # LLM requests per minute cap (auto-detected if unset)
#                                           # Groq free: ~30, OpenRouter pay-as-you-go: ~100, Groq paid: 500+

# Legacy fallback (still works, not recommended)
# LLM_API_KEY=
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Embedding Provider
# Embeddings auto-use OPENROUTER_API_KEY if set (recommended).
# Groq-only setups must also set OPENROUTER_API_KEY or EMBEDDING_API_KEY.
# EMBEDDING_API_KEY=your_openai_or_openrouter_key
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# OpenTelemetry (optional)
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=monte-engine
OTEL_ENABLED=false

# Composio (optional — enables `monte connect` for platform OAuth)
# Get your free key at https://composio.dev
COMPOSIO_API_KEY=
