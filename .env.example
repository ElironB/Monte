# Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=monte-data

# LLM - Works with any OpenAI-compatible API (Groq, OpenRouter, OpenAI, Together, etc.)
LLM_API_KEY=              # Your API key (Groq, OpenRouter, OpenAI, etc.)
LLM_BASE_URL=https://api.groq.com/openai/v1   # API base URL
LLM_MODEL=llama-3.1-70b-versatile              # Model for standard evaluation
LLM_REASONING_MODEL=                           # Optional: separate model for complex decisions
# Examples:
#   Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1       LLM_MODEL=llama-3.1-70b-versatile
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1         LLM_MODEL=meta-llama/llama-3.1-70b-instruct
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# OpenTelemetry (optional)
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=monte-engine
OTEL_ENABLED=false

# Composio
COMPOSIO_API_KEY=
