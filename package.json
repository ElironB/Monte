{
  "name": "monte-engine",
  "version": "0.1.0",
  "description": "Probabilistic life simulation platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "cli": "node dist/cli/index.js",
    "cli:dev": "tsx src/cli/index.ts"
  },
  "keywords": [
    "simulation",
    "monte-carlo",
    "probabilistic-modeling",
    "decision-support",
    "behavioral-analysis"
  ],
  "bin": {
    "monte": "dist/cli/index.js"
  },
