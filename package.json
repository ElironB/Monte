{
  "name": "monte-engine",
  "version": "0.1.1",
  "description": "Probabilistic life simulation platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "release:check": "npm run build && npm test -- --run && npm run test:benchmarks && npm run benchmark:pretty && npm pack",
    "publish:dry-run": "npm publish --dry-run",
    "benchmark": "tsx src/benchmarks/runHarness.ts --json",
    "benchmark:pretty": "tsx src/benchmarks/runHarness.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:benchmarks": "vitest run tests/benchmarks",
    "test:e2e": "tests/e2e/smoke-test.sh",
    "cli": "node dist/cli/index.js",
    "cli:dev": "tsx src/cli/index.ts"
  },
  "keywords": [
    "simulation",
    "monte-carlo",
    "probabilistic-modeling",
    "decision-support",
    "behavioral-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElironB/Monte.git"
  },
  "bugs": {
    "url": "https://github.com/ElironB/Monte/issues"
  },
  "homepage": "https://github.com/ElironB/Monte#readme",
  "bin": {
    "monte": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "AGENTS.md",
    "CONTEXT.md",
    "SKILL.md",
    "docs",
    "LICENSE"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@inquirer/prompts": "^7.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-jaeger": "^1.30.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "bullmq": "^5.41.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "minio": "^8.0.7",
    "neo4j-driver": "^5.27.0",
    "openai": "^4.73.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
